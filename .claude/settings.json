{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/block-env-access.sh\"",
            "statusMessage": "Checking for blocked .env access..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/format-on-edit.sh\"",
            "statusMessage": "Formatting with Prettier..."
          }
        ]
      }
    ]
  }
}
